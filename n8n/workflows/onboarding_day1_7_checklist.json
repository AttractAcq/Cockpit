            { "name": "Content-Type",  "value": "application/json" },
            { "name": "Prefer",        "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"entity_id\": \"{{ $('Set Context').item.json.entity_id }}\",\n  \"source\": \"n8n\",\n  \"priority\": \"high\",\n  \"status\": \"open\",\n  \"title\": \"Onboarding Day 2 — Meta Ads access not yet confirmed\",\n  \"detail\": \"Client has not confirmed Meta Business Manager access. Chase before Day 4 or campaign cannot launch on time.\"\n}"
      }
    },
    {
      "id": "a1b2c3d4-0001-0001-0001-000000000010",
      "name": "Wait 24h — Day 2→3",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [2220, 380],
      "parameters": {
        "resume": "timeInterval",
        "unit": "hours",
        "amount": 24
      }
    },
