        "jsonBody": "={\n  \"entity_id\": \"{{ $('Set Context').item.json.entity_id }}\",\n  \"agent\": \"n8n-onboarding\",\n  \"event_type\": \"onboarding_day1_started\",\n  \"payload\": { \"business_name\": \"{{ $('Set Context').item.json.business_name }}\" },\n  \"status\": \"processed\"\n}"
      }
    },
    {
      "id": "a1b2c3d4-0001-0001-0001-000000000006",
      "name": "Wait 24h — Day 1→2",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [1340, 380],
      "parameters": {
        "resume": "timeInterval",
        "unit": "hours",
        "amount": 24
      }
    },
    {
      "id": "a1b2c3d4-0001-0001-0001-000000000007",
      "name": "Day 2 — Fetch entity",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1560, 380],
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/entities?id=eq.{{ $('Set Context').item.json.entity_id }}&select=notes_signals,stage",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" }
          ]
        }
      }
    },
    {
      "id": "a1b2c3d4-0001-0001-0001-000000000008",
      "name": "Day 2 — Meta connected?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1780, 380],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "conditions": [
            {
              "id": "cond1",
              "leftValue": "={{ $json[0].notes_signals?.meta_account_connected }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        }
      }
    },
    {
      "id": "a1b2c3d4-0001-0001-0001-000000000009",
