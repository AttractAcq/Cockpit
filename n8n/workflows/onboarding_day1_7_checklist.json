        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"entity_id\": \"{{ $('Set Context').item.json.entity_id }}\",\n  \"source\": \"n8n\",\n  \"priority\": \"normal\",\n  \"status\": \"open\",\n  \"title\": \"Onboarding Day 3 — First brief still in draft\",\n  \"detail\": \"Brief has not been approved yet. Get client sign-off before campaign can launch.\"\n}"
