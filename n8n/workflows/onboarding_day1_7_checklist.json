      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "aa-onboarding-checklist-v1",
      "parameters": {
        "httpMethod": "POST",
        "path": "aa-onboarding",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-0001-0001-0001-000000000002",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [460, 200],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"ok\": true, \"workflow\": \"onboarding\", \"entity_id\": \"{{ $json.entity_id }}\" }"
      }
    },
    {
      "id": "a1b2c3d4-0001-0001-0001-000000000003",
      "name": "Set Context",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [460, 380],
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            { "id": "1", "name": "entity_id",     "value": "={{ $json.entity_id }}",     "type": "string" },
            { "id": "2", "name": "business_name", "value": "={{ $json.business_name }}", "type": "string" },
            { "id": "3", "name": "contact_phone", "value": "={{ $json.contact_phone }}", "type": "string" },
            { "id": "4", "name": "supabase_url",  "value": "={{ $env.SUPABASE_URL }}",   "type": "string" }
          ]
        }
      }
    },
    {
      "id": "a1b2c3d4-0001-0001-0001-000000000004",
      "name": "Day 1 — Welcome triage item",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [680, 380],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/triage_items",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type",  "value": "application/json" },
            { "name": "Prefer",        "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"entity_id\": \"{{ $('Set Context').item.json.entity_id }}\",\n  \"source\": \"n8n\",\n  \"priority\": \"high\",\n  \"status\": \"open\",\n  \"title\": \"Onboarding Day 1 — Welcome call scheduled\",\n  \"detail\": \"Send welcome pack, confirm Meta Ads access request sent, book 30-min onboarding call.\"\n}"
      }
    },
    {
      "id": "a1b2c3d4-0001-0001-0001-000000000021",
      "name": "Day 1 — Register in automations",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [900, 260],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/automations",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type",  "value": "application/json" },
            { "name": "Prefer",        "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"entity_id\": \"{{ $('Set Context').item.json.entity_id }}\",\n  \"name\": \"Onboarding Day 1\\u20137 Checklist\",\n  \"platform\": \"n8n\",\n  \"trigger_type\": \"webhook\",\n  \"status\": \"active\",\n  \"config\": { \"webhook_path\": \"aa-onboarding\", \"business_name\": \"{{ $('Set Context').item.json.business_name }}\" }\n}"
      }
    },
    {
      "id": "a1b2c3d4-0001-0001-0001-000000000005",
      "name": "Log Day 1 agent_event",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1120, 380],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/agent_events",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
